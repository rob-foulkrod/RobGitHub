{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.37.4.10188",
      "templateHash": "13495003178918802380"
    }
  },
  "parameters": {
    "webAppName": {
      "type": "string",
      "minLength": 2,
      "maxLength": 60,
      "metadata": {
        "description": "Globally unique name for the Azure App Service web app."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "eastus2",
      "metadata": {
        "description": "Azure region for all resources. This deployment is intended for East US 2."
      }
    },
    "appServicePlanSku": {
      "type": "string",
      "defaultValue": "S1",
      "allowedValues": [
        "S1",
        "S2",
        "S3",
        "P0v3",
        "P1v3",
        "P2v3",
        "P3v3"
      ],
      "metadata": {
        "description": "SKU name for the Linux App Service plan. Standard or higher is required for deployment slots."
      }
    },
    "healthCheckPath": {
      "type": "string",
      "defaultValue": "/health",
      "metadata": {
        "description": "Health-check endpoint exposed by the application."
      }
    }
  },
  "variables": {
    "appServicePlanName": "[format('{0}-plan', parameters('webAppName'))]",
    "appServicePlanTier": "[if(startsWith(parameters('appServicePlanSku'), 'P'), 'PremiumV3', 'Standard')]",
    "commonSiteConfig": {
      "alwaysOn": true,
      "ftpsState": "Disabled",
      "healthCheckPath": "[parameters('healthCheckPath')]",
      "http20Enabled": true,
      "linuxFxVersion": "DOTNETCORE|10.0",
      "minTlsVersion": "1.2"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2024-04-01",
      "name": "[variables('appServicePlanName')]",
      "location": "[parameters('location')]",
      "kind": "linux",
      "sku": {
        "name": "[parameters('appServicePlanSku')]",
        "tier": "[variables('appServicePlanTier')]"
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2024-04-01",
      "name": "[parameters('webAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "httpsOnly": true,
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "siteConfig": "[union(variables('commonSiteConfig'), createObject('appSettings', createArray(createObject('name', 'ASPNETCORE_ENVIRONMENT', 'value', 'Production'), createObject('name', 'WEBSITE_RUN_FROM_PACKAGE', 'value', '1'))))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites/slots",
      "apiVersion": "2024-04-01",
      "name": "[format('{0}/{1}', parameters('webAppName'), 'staging')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "httpsOnly": true,
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "siteConfig": "[union(variables('commonSiteConfig'), createObject('appSettings', createArray(createObject('name', 'ASPNETCORE_ENVIRONMENT', 'value', 'Staging'), createObject('name', 'WEBSITE_RUN_FROM_PACKAGE', 'value', '1'))))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "[resourceId('Microsoft.Web/sites', parameters('webAppName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2024-04-01",
      "name": "[format('{0}/{1}', parameters('webAppName'), 'slotConfigNames')]",
      "properties": {
        "appSettingNames": [
          "ASPNETCORE_ENVIRONMENT"
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('webAppName'))]"
      ],
      "metadata": {
        "description": "Marks environment configuration as sticky so it remains attached to its slot after a swap."
      }
    }
  ],
  "outputs": {
    "webAppName": {
      "type": "string",
      "value": "[parameters('webAppName')]"
    },
    "productionUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', parameters('webAppName')), '2024-04-01').defaultHostName)]"
    },
    "stagingUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites/slots', parameters('webAppName'), 'staging'), '2024-04-01').defaultHostName)]"
    }
  }
}